{
  "name": "leader-line",
  "version": "1.0.8",
  "title": "LeaderLine",
  "description": "Draw a leader line in your web page.",
  "packageManager": "bun@1.3.13",
  "keywords": [
    "leader",
    "line",
    "markup",
    "arrow",
    "attention",
    "highlight",
    "spotlight",
    "bubble",
    "svg"
  ],
  "main": "./leader-line.min.js",
  "module": "./leader-line.mjs",
  "exports": {
    ".": {
      "import": "./leader-line.mjs",
      "default": "./leader-line.mjs"
    },
    "./leader-line.min.js": "./leader-line.min.js",
    "./leader-line.mjs": "./leader-line.mjs"
  },
  "files": [
    "leader-line.min.js",
    "leader-line.mjs",
    "bower.json"
  ],
  "devDependencies": {
    "anim-event": "1.0.16",
    "cheerio": "1.0.0-rc.9",
    "clean-css": "5.1.2",
    "esbuild": "0.25.12",
    "htmlclean": "3.0.8",
    "jasmine-core": "3.7.1",
    "oxlint": "^1.61.0",
    "plain-draggable": "2.5.12",
    "pre-proc": "1.0.2",
    "test-page-loader": "1.0.8"
  },
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "defs": "bun ./scripts/defs.mjs",
    "funcs": "bun ./scripts/funcs.mjs",
    "build": "bun ./scripts/build.mjs",
    "test": "bun ./test/httpd.mjs"
  },
  "homepage": "https://anseki.github.io/leader-line/",
  "repository": {
    "type": "git",
    "url": "git://github.com/anseki/leader-line.git"
  },
  "bugs": "https://github.com/anseki/leader-line/issues",
  "license": "MIT",
  "author": {
    "name": "anseki",
    "url": "https://github.com/anseki"
  }
}
